class Solution {
public:
    int integerReplacement(int n) {
        int sum=0;
        long long m=n;
        while(m>1)
        {
            sum++;
            if(m%2)
            {
                if(m/2%2==0||m-1==2)m--;
                else m++;
            }
            else
            {
                m/=2;
            }
        }
        return sum;
    }
};