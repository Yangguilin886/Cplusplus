#include <bits/stdc++.h>
#define int long long
using namespace std;
const int N=100001;
int n,k;
int a[N];
struct egd
{
  int y,w;
};
map<pair<int,int>,int> st;
vector<egd> g[N];
bool dfs(int start,int dm,int father,int end,int sum)
{
  if(dm==end)
  {
    st[{start,end}]=st[{end,start}]=sum;
    return true;
  }
  for(vector<egd> :: iterator it = g[dm].begin(); it != g[dm].end(); it++)
  {
    int son=it->y;
    if(son==father)continue;
    int w=it->w;
    if(dfs(start,son,dm,end,sum+w))return true;
  }
  return false;
}
signed main()
{
  cin>>n>>k;
  for(int i=0;i<n-1;i++)
  {
    int x,y,w;
    cin>>x>>y>>w;
    g[x].push_back({y,w});
    g[y].push_back({x,w});
  }
  for(int i=0;i<k;i++)
  {
    cin>>a[i];
  }
  int ant=0;
  for(int i=0;i<k;i++)
  {
    dfs(a[i],a[i],-1,a[i+1],0);
    ant+=st[{a[i],a[i+1]}];
  }
  for(int i=0;i<k;i++)
  {
    int tmp=ant;
    if(i==0)tmp-=st[{a[i],a[i+1]}];
    else if(i==k-1)tmp-=st[{a[i-1],a[i]}];
    else
    {
      tmp-=st[{a[i-1],a[i]}];
      tmp-=st[{a[i],a[i+1]}];
      dfs(a[i-1],a[i-1],-1,a[i+1],0);
      tmp+=st[{a[i-1],a[i+1]}];
    }
    cout<<tmp<<" ";
  }
  return 0;
}