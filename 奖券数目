#include <iostream>
using namespace std;
int main()
{
  int sum=0;
  for(int i=10000;i<=99999;i++)
  {
    int flag=1;
    int n=i;
    while(n>0)
    {
      if(n%10==4)
      {
        flag=0;
        break;
      }
      n/=10;
    }
    if(flag)sum++;
  }
  cout<<sum<<endl;
  return 0;
}