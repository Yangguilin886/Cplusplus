class Solution {
public:
    vector<int> diStringMatch(string s) {
        int n=s.size(),m=0;
        vector<int> ret;
        for(int i=0;i<s.size();i++)
        {
            if(s[i]=='I')
            {
                ret.push_back(m);
                m++;
            }
            else
            {
                ret.push_back(n);
                n--;
            }
        }
        ret.push_back(n);
        return ret;
    }
};