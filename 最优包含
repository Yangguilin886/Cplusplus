#include <bits/stdc++.h>
using namespace std;
int main()
{ 
  string s1,s2;
  cin>>s1>>s2;
  int n=s1.size(),m=s2.size();
  s1=' '+s1;
  s2=' '+s2;
  vector<vector<int>> dp(n+1,vector<int>(m+1,0x3f3f3f3f));
  for(int i=0;i<=m;i++)
  {
    dp[i][0]=0;
  }
  for(int i=1;i<=n;i++)
  {
    for(int j=1;j<=m&&i>=j;j++)
    {
      if(s1[i]==s2[j])dp[i][j]=dp[i-1][j-1];
      else dp[i][j]=min(dp[i-1][j-1]+1,dp[i-1][j]);
    }
  }
  cout<<dp[n][m]<<endl;
  return 0;
}