#include <bits/stdc++.h>
using namespace std;
int main()
{
  string s;
  cin>>s;
  int flag=0;
  int m=0;
  for(int i=0;i<s.size();i++)
  {
    if(s[i]=='a'||s[i]=='e'||s[i]=='o'||s[i]=='i'||s[i]=='u')
    {
      if(flag==1)
      {
        m++;
        flag=0;
      }
    }
    else
    {
      if(flag==0)
      {
        m++;
        flag=1;
      }
    }
  }
  if(m==4)cout<<"yes"<<endl;
  else cout<<"no"<<endl;
  return 0;
}