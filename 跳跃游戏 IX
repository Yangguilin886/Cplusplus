class Solution {
public:
    vector<int> maxValue(vector<int>& nums) {
        int n=nums.size();
        vector<int> ret(n);
        vector<int> dp(n);
        dp[0]=nums[0];
        for(int i=1;i<n;i++)
        {
            dp[i]=max(dp[i-1],nums[i]);
        }
        int min_i=INT_MAX;
        for(int i=n-1;i>=0;i--)
        {
            ret[i]=dp[i]<=min_i?dp[i]:ret[i+1];
            min_i=min(min_i,nums[i]);
        }
        return ret;
    }
};