#include<iostream>
#include<string>
using namespace std;
bool issame(string s)
{
    int left = 0, right = 0;
    int i = 0, j = s.size() - 1;
    while (i < j)
    {
        left += s[i++] - '0';
        right += s[j--] - '0';
    }
    return left == right;
}
int main()
{
    int sum = 0;
    for (int i = 1; i <= 100000000; i++)
    {
        string s = to_string(i);
        if (s.size() % 2)continue;
        if (issame(s))sum++;
    }
    cout << sum << endl;
    return 0;
}