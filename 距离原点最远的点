class Solution {
public:
    int furthestDistanceFromOrigin(string moves) {
        int left=0,right=0,sum=0;
        for(int i=0;i<moves.size();i++)
        {
            if(moves[i]=='L')left++;
            else if(moves[i]=='R')right++;
            else sum++;
        }
        if(left>right)return left+sum-right;
        else return right-left+sum;
    }
};