class Solution {
public:
    int smallestRangeII(vector<int>& nums, int k) {
        sort(nums.begin(),nums.end());
        int n=nums.size();
        int min_i=nums[n-1]-nums[0];
        for(int i=1;i<n;i++)
        {
            int m=max(nums[i-1]+k,nums[n-1]-k)-min(nums[0]+k,nums[i]-k);
            min_i=min(min_i,m);
        }
        return min_i;
    }
};