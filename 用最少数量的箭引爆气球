class Solution {
public:
    int findMinArrowShots(vector<vector<int>>& nums) {
        sort(nums.begin(),nums.end());
        int sum=1;
        int y1=nums[0][1];
        for(int i=1;i<nums.size();i++)
        {
            int x2=nums[i][0],y2=nums[i][1];
            if(x2>y1)
            {
                sum++;
                y1=y2;
            }
            else
            {
                y1=min(y1,y2);
            }
        }
        return sum;
    }
};