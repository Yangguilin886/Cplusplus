#include <bits/stdc++.h>
using namespace std;
int dx[4]={1,-1,0,0};
int dy[4]={0,0,1,-1};
int main()
{
  int n,m;
  cin>>n>>m;
  vector<string> ret(n);
  for(int i=0;i<n;i++)
  {
    cin>>ret[i];
  }
  int k;
  cin>>k;
  while(k--)
  {
    bool dp[1000][1000]={false};
    for(int i=0;i<n;i++)
    {
      for(int j=0;j<m;j++)
      {
        if(ret[i][j]=='g'&&dp[i][j]==false)
        {
          for(int k=0;k<4;k++)
          {
            int a=i+dx[k];
            int b=j+dy[k];
            if(a>=0&&a<n&&b>=0&&b<m&&ret[a][b]=='.')
            {
              ret[a][b]='g';
              dp[a][b]=true;
            }
          }
        }
      }
    }
  }
  for(int i=0;i<n;i++)
  {
    for(int j=0;j<m;j++)
    {
      cout<<ret[i][j];
    }
    cout<<endl;
  }
  return 0;
}