#include <bits/stdc++.h>
using namespace std;
int main()
{
  int n;
  cin>>n;
  vector<int> ret(n);
  for(int i=0;i<n;i++)
  {
    cin>>ret[i];
  }
  int max_i=0;
  for(int i=0;i<n;i++)
  {
    for(int j=i+1;j<n;j++)
    {
      max_i=max(max_i,abs(i-j)+abs(ret[i]-ret[j]));
    }
  }
  cout<<max_i<<endl;
  return 0;
}