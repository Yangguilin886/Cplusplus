#include <bits/stdc++.h>
#define int long long
const int mod=1e9+7;
using namespace std;
signed main()
{
  int ret0[1000000]={0};
  int ret1[1000000]={0};
  int dp[1000000]={0};
  ret0[1]=1;
  ret0[2]=0;
  ret1[1]=0;
  ret1[2]=1;
  for(int i=3;i<100002;i++)
  {
    dp[i]=(dp[i-1]+dp[i-2]+ret1[i-2]*ret0[i-1])%mod;
    ret0[i]=(ret0[i-1]+ret0[i-2])%mod;
    ret1[i]=(ret1[i-1]+ret1[i-2])%mod;
  }
  int t;
  cin>>t;
  while(t--)
  {
    int n;
    cin>>n;
    cout<<dp[n]<<endl;
  }
  return 0;
}