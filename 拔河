#include <bits/stdc++.h>
#define int long long
using namespace std;
signed main()
{
  int n;
  cin>>n;
  vector<int> ret(n);
  for(int i=1;i<n;i++)
  {
    cin>>ret[i];
  }
  vector<int> dp;
  dp.push_back(0);
  for(int i=1;i<n;i++)
  {
    int tmp=0;
    for(int j=i;j<n;j++)
    {
      tmp+=ret[j];
      dp.push_back(tmp);
    }
  }
  sort(dp.begin(),dp.end());
  int min_i=LLONG_MAX;
  for(int i=1;i<dp.size();i++)
  {
    min_i=min(dp[i]-dp[i-1],min_i);
  }
  cout<<min_i<<endl;
  return 0;
}