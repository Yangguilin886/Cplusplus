#include <bits/stdc++.h>
using namespace std;
int m,n;
int dp[1005][1005];
int main()
{
  cin>>m>>n;
  for(int i=1;i<=n;i++)
  {
    dp[1][i]=1;
  }
  for(int i=2;i<=m;i++)
  {
    for(int j=1;j<=n;j++)
    {
      if(i%2)
      {
        int tmp=0;
        for(int k=j-1;k>=1;k--)
        {
          tmp+=dp[i-1][k]%10000;
        }
        dp[i][j]=tmp;
      }
      else
      {
        int tmp=0;
        for(int k=j+1;k<=n;k++)
        {
          tmp+=dp[i-1][k]%10000;
        }
        dp[i][j]=tmp;
      }
    }
  }
  long long sum=0;
  for(int i=1;i<=n;i++)
  {
    sum+=dp[m][i];
  }
  cout<<sum%10000<<endl;
  return 0;
}