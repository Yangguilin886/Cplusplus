#include <bits/stdc++.h>
using namespace std;
bool goodsum(string s)
{
  int flag=1;
  for(int i=s.size()-1;i>=0;i--)
  {
    int x=s[i]-'0';
    if(x%2!=flag%2)return false;
    flag++;
  }
  return true;
}
int main()
{
  int n;
  cin>>n;
  int sum=0;
  for(int i=1;i<=n;i++)
  {
    if(goodsum(to_string(i)))sum++;
  }
  cout<<sum<<endl;
  return 0;
}