class Solution {
public:
    int brokenCalc(int begin, int end) {
        int sum=0;
        while(end!=begin)
        {
            if(end<begin)
            {
                sum+=begin-end;
                break;
            }
            if(end%2)end++;
            else
            {
                end/=2;
            }
            sum++;
        }
        return sum;
    }
};