class Solution {
public:
    int largestPerimeter(vector<int>& nums) {
        sort(nums.begin(),nums.end());
        int sum=0;
        for(int i=nums.size()-1;i>1;i--)
        {
            int x=nums[i-1];
            int y=nums[i-2];
            if(x+y>nums[i])return x+y+nums[i];
        }
        return 0;
    }
};