#include <bits/stdc++.h>
#define int long long
using namespace std;
signed main()
{
  int n;
  cin>>n;
  vector<vector<int>> ret(3,vector<int>(n));
  for(int i=0;i<3;i++)
  {
    for(int j=0;j<n;j++)
    {
      cin>>ret[i][j];
    }
  }
  vector<vector<int>> dp(3,vector<int>(n));
  for(int j=0;j<n;j++)
  {
    dp[0][j]=ret[0][j]-ret[1][j]-ret[2][j];
    dp[1][j]=ret[1][j]-ret[0][j]-ret[2][j];
    dp[2][j]=ret[2][j]-ret[0][j]-ret[1][j];
  }
  for(int i=0;i<3;i++)
  {
    sort(dp[i].begin(),dp[i].end());
  }
  int flag=0;
  for(int i=0;i<3;i++)
  {
    int sum=0;
    int m=0;
    for(int j=n-1;j>=0;j--)
    {
      sum+=dp[i][j];
      if(sum<=0)break;
      m++;
    }
    flag=max(flag,m);
  }
  if(flag==0)cout<<-1<<endl;
  else cout<<flag<<endl;
  return 0;
}