class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int max_i=0;
        int flag=prices[0];
        for(int i=1;i<prices.size();i++)
        {
            if(prices[i]>=flag)max_i=max(max_i,prices[i]-flag);
            else flag=prices[i];
        }
        return max_i;
    }
};