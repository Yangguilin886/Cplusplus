#include<bits/stdc++.h>
using namespace std;
int main()
{
    int N=0;
    cin>>N;
    vector<vector<int>> ret;
    for(int i=0;i<N;i++)
    {
        int x=0;
        vector<int> tmp;
        while(cin>>x)
        {
            tmp.push_back(x);
        }
        ret.push_back(tmp);
    }
    unordered_map<int,int> hash;
    int max_i=0,min_i=1000000;
    for(int i=0;i<N;i++)
    {
        int M=ret[i].size();
        for(int j=0;j<M;j++)
        {
            hash[ret[i][j]]++;
            max_i=max(max_i,ret[i][j]);
            min_i=min(min_i,ret[i][j]);
        }
    }
    int m=0,n=0;
    for(int i=min_i;i<=max_i;i++)
    {
        if(!hash.count(i))m=i;
        if(hash[i]==2)n=i;
    }
    cout<<m<<" "<<n<<endl;
    return 0;
}