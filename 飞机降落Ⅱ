#include <bits/stdc++.h>
using namespace std;
bool dp[15];
bool flag;
int N;
vector<vector<int>> ret(11,vector<int>(3));
void dfs(int n,int cnt,int sum)
{
  if(cnt==n)
  {
    flag=true;
    return;
  }
  for(int i=0;i<n;i++)
  {
    if(!dp[i]&&ret[i][0]+ret[i][1]>=sum)
    {
      dp[i]=true;
      dfs(n,cnt+1,max(sum,ret[i][0])+ret[i][2]);
      dp[i]=false;
    }
  }
}
int main()
{
  int T;
  cin>>T;
  while(T--)
  {
    int N;
    cin>>N;
    for(int i=0;i<N;i++)
    {
      for(int j=0;j<3;j++)
      {
        cin>>ret[i][j];
      }
    }
    flag=false;
    dfs(N,0,0);
    if(flag)cout<<"YES"<<endl;
    else cout<<"NO"<<endl;
  }
  return 0;
}