class Solution {
public:
    string customSortString(string order, string s) {
        unordered_map<char,int> hs;
        for(int i=0;i<order.size();i++)
        {
            hs[order[i]]=i;
        }
        sort(s.begin(),s.end(),[&](char& x,char& y)
        {
            return hs[x]<hs[y];
        });
        return s;
    }
};