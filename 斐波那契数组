#include <bits/stdc++.h>
using namespace std;
int main()
{
  int n;
  cin>>n;
  vector<int> ret(n);
  for(int i=0;i<n;i++)
  {
    cin>>ret[i];
  }
  vector<int> dp(1000000);
  vector<int> a(100000);
  for(int i=0;i<n;i++)
  {
    if(i<2)
    {
      a[i]=1;
    }
    else
    {
      a[i]=a[i-1]+a[i-2];
    }
    if(ret[i]%a[i]==0)
    dp[ret[i]/a[i]]++;
  }
  int max_i=0;
  for(int i=1;i<100001;i++)
  {
    max_i=max(max_i,dp[i]);
  }
  n-=max_i;
  cout<<n<<endl;
  return 0;
}