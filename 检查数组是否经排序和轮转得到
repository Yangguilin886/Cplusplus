class Solution {
public:
    bool check(vector<int>& nums) {
        int n=nums.size();
        int i=1;
        for(;i<n;i++)
        {
            if(nums[i]<nums[i-1])break;
        }
        for(int j=i;j<n;j++)
        {
            if(nums[j]>nums[0])return false;
            if(j!=i&&nums[j]<nums[j-1])return false;
        }
        return true;
    }
};