class Solution {
public:
    bool isGood(vector<int>& nums) {
        sort(nums.begin(),nums.end());
        int n=nums.size();
        if(n-1!=nums[n-1])return false;
        for(int i=0;i<n-1;i++)
        {
            if(i+1!=nums[i])return false;
        }
        return true;
    }
};