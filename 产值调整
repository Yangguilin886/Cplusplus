#include <bits/stdc++.h>
using namespace std;
int main()
{
  int t;
  cin>>t;
  while(t--)
  {
    long long a,b,c,k;
    cin>>a>>b>>c>>k;
    if(k>40)k=40;
    while(k--)
    {
      long long a1=(b+c)/2;
      long long b1=(a+c)/2;
      long long c1=(a+b)/2;
      a=a1;
      b=b1;
      c=c1;
    }
    cout<<a<<' '<<b<<' '<<c<<endl;
  }
  return 0;
}