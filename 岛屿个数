#include <bits/stdc++.h>
using namespace std;
int dx[4]={1,0,-1,0};
int dy[4]={0,1,0,-1};
char c;
int sum,m,n;
bool dp[52][52];
int ret[52][52];
void dfs(int x,int y)
{
  dp[x][y]=true;
  for(int i=0;i<4;i++)
  {
    int a=x+dx[i];
    int b=y+dy[i];
    if(ret[a][b]==0||dp[a][b])continue;
    dfs(a,b);
  }
}
void sea(int x,int y)
{
  dp[x][y]=true;
  for(int i=-1;i<=1;i++)
  {
    for(int j=-1;j<=1;j++)
    {
      int a=x+i;
      int b=y+j;
      if(a<0||a>n+1||b<0||b>m+1||dp[a][b])continue;
      if(ret[a][b]==0) sea(a,b);
      else dfs(a,b),sum++;
    }
  }
}
int main()
{
  int T;
  cin>>T;
  while(T--)
  {
    memset(dp,false,sizeof dp);
    memset(ret,0,sizeof ret);
    cin>>n>>m;
    sum=0;
    for(int i=1;i<=n;i++)
    {
      for(int j=1;j<=m;j++)
      {
        cin>>c;
        ret[i][j]=c-'0';
      }
    }
    sea(0,0);
    cout<<sum<<endl;
  }
  return 0;
}