#include <bits/stdc++.h>
using namespace std;
int main()
{
  int n;
  cin>>n;
  vector<int> ret(n);
  for(int i=0;i<n;i++)
  {
    cin>>ret[i];
  }
  int a=0,b=0;
  for(int i=0;i<n;i++)
  {
    if(ret[i]>=60)a++;
    if(ret[i]>=85)b++;
  }
  a=a*1000/n;
  b=b*1000/n;
  if(a%10>=5)
  {
    a=a/10+1;
  }
  else a/=10;
  if(b%10>=5)b=b/10+1;
  else b/=10;
  cout<<a<<'%'<<endl;
  cout<<b<<'%'<<endl;
  return 0;
}