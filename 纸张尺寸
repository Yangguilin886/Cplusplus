#include <bits/stdc++.h>
using namespace std;
int main()
{
  string s;
  cin>>s;
  int n=s[1]-'0';
  vector<int> a(10);
  a[0]=1189;
  int m=841;
  if(n==0)cout<<1189<<endl<<841<<endl;
  for(int i=1;i<10;i++)
  {
    int flag=m;
    m=a[i-1]/2;
    a[i]=flag;
    if(i==n)
    {
      cout<<a[i]<<endl<<m<<endl;
      break;
    }
  }
  return 0;
}