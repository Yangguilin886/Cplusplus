#include <bits/stdc++.h>
using namespace std;
int main()
{
  string s;
  cin>>s;
  vector<int> ret(26);
  int n=0;
  char tmp='a';
  for(int i=0;i<s.size();i++)
  {
    int j=s[i];
    ret[j-97]++;
  }
  for(int i=0;i<26;i++)
  {
    if(ret[i]>n)
    {
      tmp='a'+i;
      n=ret[i];
    }
  }
  cout<<tmp<<endl;
  cout<<n<<endl;
  return 0;
}