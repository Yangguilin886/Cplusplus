#include<bits/stdc++.h>
using namespace std;
struct point
{
    int num;
    int dis;
};
void merge(vector<point>& ret,int left,int right,vector<point>& tmp)
{
    if(left>=right)return;
    int mid=(left+right)/2;
    merge(ret,left,mid,tmp);
    merge(ret,mid+1,right,tmp);
    int start1=left,end1=mid;
    int start2=mid+1,end2=right;
    int i=left;
    while(start1<=end1&&start2<=end2)
    {
        if(ret[start1].num<=ret[start2].num)
        {
            ret[start1].dis+=start2-mid-1;
            tmp[i++]=ret[start1++];
        }
        else
        {
            ret[start2].dis+=mid+1-start1;
            tmp[i++]=ret[start2++];
        }
    }
    while(start2<=end2)tmp[i++]=ret[start2++];
    start2--;
    while(start1<=end1)
    {
        ret[start1].dis+=start2-mid;
        tmp[i++]=ret[start1++];
    }
    for(int i=left;i<=right;i++)
    {
        ret[i]=tmp[i];
    }
}
int main()
{
    int n=0;
    int sum=0;
    cin>>n;
    vector<point> ret;
    vector<point> tmp(n);
    for(int i=0;i<n;i++)
    {
        int a;
        cin>>a;
        ret.push_back({a,0});
    }
    merge(ret,0,n-1,tmp);
    for(int i=0;i<n;i++)
    {
        sum+=ret[i].dis*(ret[i].dis+1)/2;
    }
    cout<<sum<<endl;
    return 0;
}