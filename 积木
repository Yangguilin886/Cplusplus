#include <bits/stdc++.h>
#define int long long
using namespace std;
signed main()
{
  int n,m;
  cin>>n>>m;
  vector<vector<int>> ret(n,vector<int>(m));
  for(int i=0;i<n;i++)
  {
    for(int j=0;j<m;j++)
    {
      cin>>ret[i][j];
    }
  }
  int h;
  cin>>h;
  int sum=0;
  for(int i=0;i<n;i++)
  {
    for(int j=0;j<m;j++)
    {
      if(ret[i][j]>=h)
      {
        sum++;
        ret[i][j]=0;
      }
    }
  }
  vector<int> dp(h+1,sum);
  for(int i=0;i<n;i++)
  {
    for(int j=0;j<m;j++)
    {
      for(int k=1;k<=ret[i][j];k++)
      {
        if(k>h)break;
        dp[k]++;
      }
    }
  }
  int a=0;
  for(int i=1;i<=h;i++)
  {
    a+=dp[i];
    cout<<a<<endl;
  }
  return 0;
}