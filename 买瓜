#include <bits/stdc++.h>
#define int long long 
using namespace std;
int flag=50;
int n,m;
int ret[50]={0};
int tmp[50]={0};
void dfs(int i,int w,int d)
{
  if(d>=flag)return;
  if(w==m)flag=min(flag,d);
  if(i>=n||w>=m||w+tmp[i]<m)return;
  dfs(i+1,w+ret[i]/2,d+1);
  dfs(i+1,w+ret[i],d);
  dfs(i+1,w,d);
}
signed main()
{
  cin>>n>>m;
  for(int i=0;i<n;i++)
  {
    cin>>ret[i];
  }
  for(int i=0;i<n;i++)
  {
    ret[i]*=2;
  }
  m*=2;
  sort(ret,ret+n,greater<>());
  for(int i=n-1;i>=0;i--)
  {
    tmp[i]=tmp[i+1]+ret[i];
  }
  dfs(0,0,0);
  if(flag==50)cout<<-1;
  else
  cout<<flag<<endl;
  return 0;
}