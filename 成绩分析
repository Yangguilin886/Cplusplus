#include <bits/stdc++.h>
using namespace std;
int main()
{
  int n;
  cin>>n;
  vector<int> ret(n);
  int sum=0;
  int max_i=0,min_i=100;
  for(int i=0;i<n;i++)
  {
    cin>>ret[i];
    sum+=ret[i];
    max_i=max(max_i,ret[i]);
    min_i=min(min_i,ret[i]);
  }
  double m=sum*100/n;
  double a=sum*100%n;
  if(a*10/n>=5)m++;
  m=m/100.0;
  cout<<max_i<<endl<<min_i<<endl;
  printf("%.2f",m);
  return 0;
}