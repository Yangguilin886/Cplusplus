#include <bits/stdc++.h>
using namespace std;
int ret[10001];
int dp[10001];
void f(int n)
{
  for(int i=0;i<n;i++)
  {
    ret[i]++;
    dp[i]=max(dp[i],ret[i]);
  }
}
int main()
{
  int n;
  cin>>n;
  for(int i=0;i<n;i++)
  {
    f(n);
    ret[i]=0;
  }
  for(int i=n-2;i>=0;i--)
  {
    f(n);
    ret[i]=0;
  }
  for(int i=1;i<n;i++)
  {
    f(n);
    ret[i]=0;
  }
  for(int i=0;i<n;i++)
  {
    cout<<dp[i]<<endl;
  }
  return 0;
}